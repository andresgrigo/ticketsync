<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.ticketsync.controller.PosController"
            prefWidth="900" prefHeight="600"
            fx:id="root">

    <top>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <Label text="Event:"/>
            <TextField fx:id="eventSearchField" promptText="Filter events..." prefWidth="150"/>
            <ComboBox fx:id="eventComboBox" prefWidth="220"/>
            <Label fx:id="eventStatusLabel" HBox.hgrow="ALWAYS"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="vendorInfoLabel"/>
            <Button fx:id="logoutButton" text="Logout" onAction="#handleLogout"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="16">
            <Label fx:id="noEventsLabel"
                   text="No active events. Contact an administrator to activate an event."
                   style="-fx-text-fill: #757575;"
                   visible="false" managed="false"/>
            <Label fx:id="selectedEventLabel"/>
            <Label text="Seat map coming in the future."
                   style="-fx-text-fill: #9E9E9E; -fx-font-size: 14;"/>
        </VBox>
    </center>

</BorderPane>
