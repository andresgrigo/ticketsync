<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.ticketsync.controller.PosController"
            prefWidth="1200" prefHeight="760"
            fx:id="root">

    <top>
        <VBox spacing="8">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="12" right="12" bottom="0" left="12"/>
                </padding>
                <Label text="Event:"/>
                <TextField fx:id="eventSearchField" promptText="Filter events..." prefWidth="150"/>
                <ComboBox fx:id="eventComboBox" prefWidth="220"/>
                <Label fx:id="eventStatusLabel" HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="systemHealthBadgeLabel"
                       text="✓ ACID Protected"
                       style="-fx-background-color: #E8F5E9; -fx-text-fill: #2E7D32; -fx-background-radius: 16; -fx-padding: 6 12 6 12; -fx-font-weight: bold;"/>
                <Label fx:id="vendorInfoLabel"/>
                <Button fx:id="logoutButton" text="Logout" onAction="#handleLogout"/>
            </HBox>

            <HBox spacing="18" alignment="CENTER_LEFT"
                  style="-fx-background-color: #FAFAFA; -fx-border-color: #E0E0E0; -fx-border-width: 1 0 1 0;">
                <padding>
                    <Insets top="10" right="12" bottom="10" left="12"/>
                </padding>
                <Label fx:id="eventContextLabel" text="Event: No event selected"/>
                <Label fx:id="availableSeatsContextLabel" text="Available Seats: 0"/>
                <Label fx:id="boothContextLabel" text="Booth: Unassigned"/>
                
                <Label fx:id="lastSyncContextLabel" text="Last Sync: Pending"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="12">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <Label fx:id="noEventsLabel"
                   text="No active events. Contact an administrator to activate an event."
                   style="-fx-text-fill: #757575;"
                   visible="false" managed="false"/>

            <SplitPane dividerPositions="0.70" VBox.vgrow="ALWAYS">
                <items>
                    <StackPane minWidth="480.0" prefWidth="700.0" prefHeight="520.0">
                        <children>
                            <StackPane fx:id="seatMapContainer"
                                       minWidth="480.0"
                                       prefWidth="700.0"
                                       prefHeight="520.0"/>
                        </children>
                    </StackPane>

                    <StackPane minWidth="280.0" prefWidth="320.0" prefHeight="520.0">
                        <children>
                            <StackPane fx:id="selectionPanelContainer"
                                       minWidth="280.0"
                                       prefWidth="320.0"
                                       prefHeight="520.0"/>
                        </children>
                    </StackPane>
                </items>
            </SplitPane>
        </VBox>
    </center>

</BorderPane>
