<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<BorderPane prefWidth="900" prefHeight="650"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.ticketsync.controller.AdminDashboardController">

    <!-- TOP — Header bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #1565C0;">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <Label text="TicketSync Admin"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="loggedInUserLabel"
                   style="-fx-text-fill: #BBDEFB; -fx-font-size: 13px;"/>
            <Button fx:id="logoutButton" text="Logout" onAction="#handleLogout"/>
        </HBox>
    </top>

    <!-- CENTER — TabPane -->
    <center>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE">

            <!-- Users Tab -->
            <Tab text="Users" fx:id="usersTab">
                <content>
                    <fx:include fx:id="usersTabContent" source="UsersTab.fxml"/>
                </content>
            </Tab>

            <!-- Events Tab -->
            <Tab text="Events">
                <content>
                    <fx:include fx:id="eventsTabContent" source="EventsTab.fxml"/>
                </content>
            </Tab>
            <!-- Seating Tab -->
            <Tab text="Seating" fx:id="seatingTab">
                <content>
                    <fx:include fx:id="seatingTabContent" source="SeatingTab.fxml"/>
                </content>
            </Tab>

            <!-- Layout View Tab -->
            <Tab text="Layout View" fx:id="layoutViewTab">
                <content>
                    <fx:include fx:id="layoutViewTabContent" source="LayoutViewTab.fxml"/>
                </content>
            </Tab>

        </TabPane>
    </center>

</BorderPane>
