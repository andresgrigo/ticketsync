<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="900" prefHeight="650"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.ticketsync.controller.AdminDashboardController">

    <!-- TOP — Header bar + database health banner -->
    <top>
        <VBox spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="16"
                  styleClass="admin-header-bar">
                <padding>
                    <Insets top="12" right="12" bottom="12" left="12"/>
                </padding>
                <Label text="TicketSync Admin"
                       styleClass="admin-header-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="systemHealthBadgeLabel"
                       text="DB Connected"
                       styleClass="system-health-badge"/>
                <Label fx:id="loggedInUserLabel"
                       styleClass="admin-header-meta"/>
                <Button fx:id="logoutButton" text="Logout" onAction="#handleLogout"/>
            </HBox>

            <HBox fx:id="systemHealthBanner"
                  spacing="10"
                  alignment="CENTER_LEFT"
                  visible="false"
                  managed="false"
                  styleClass="system-health-banner">
                <padding>
                    <Insets top="10" right="12" bottom="10" left="12"/>
                </padding>
                <Label fx:id="systemHealthBannerLabel"
                       wrapText="true"
                       styleClass="system-health-banner-label"/>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER — TabPane -->
    <center>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE">

            <!-- Users Tab -->
            <Tab text="Users" fx:id="usersTab">
                <content>
                    <fx:include fx:id="usersTabContent" source="UsersTab.fxml"/>
                </content>
            </Tab>

            <!-- Events Tab -->
            <Tab text="Events">
                <content>
                    <fx:include fx:id="eventsTabContent" source="EventsTab.fxml"/>
                </content>
            </Tab>
            <!-- Seating Tab -->
            <Tab text="Seating" fx:id="seatingTab">
                <content>
                    <fx:include fx:id="seatingTabContent" source="SeatingTab.fxml"/>
                </content>
            </Tab>

            <!-- Layout View Tab -->
            <Tab text="Layout View" fx:id="layoutViewTab">
                <content>
                    <fx:include fx:id="layoutViewTabContent" source="LayoutViewTab.fxml"/>
                </content>
            </Tab>

            <!-- Audit Log Tab -->
            <Tab text="Audit Log" fx:id="auditLogTab">
                <content>
                    <fx:include fx:id="auditLogTabContent" source="AuditLogTab.fxml"/>
                </content>
            </Tab>

        </TabPane>
    </center>

</BorderPane>
