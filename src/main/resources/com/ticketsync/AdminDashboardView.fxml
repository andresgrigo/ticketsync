<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="900" prefHeight="650"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.ticketsync.controller.AdminDashboardController">

    <!-- TOP — Header bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #1565C0;">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <Label text="TicketSync Admin"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="loggedInUserLabel"
                   style="-fx-text-fill: #BBDEFB; -fx-font-size: 13px;"/>
            <Button fx:id="logoutButton" text="Logout" onAction="#handleLogout"/>
        </HBox>
    </top>

    <!-- CENTER — TabPane -->
    <center>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE">

            <!-- Users Tab -->
            <Tab text="Users" fx:id="usersTab">
                <content>
                    <BorderPane>
                        <top>
                            <ToolBar fx:id="usersToolbar">
                                <Button fx:id="createUserButton" text="+ Create User"
                                        onAction="#handleCreateUser"/>
                                <Button fx:id="editUserButton" text="Edit User"
                                        onAction="#handleEditUser" disable="true"/>
                                <Button fx:id="deleteUserButton" text="Delete User"
                                        onAction="#handleDeleteUser" disable="true"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="statusLabel"
                                       style="-fx-text-fill: #666;"/>
                            </ToolBar>
                        </top>
                        <center>
                            <TableView fx:id="usersTable">
                                <placeholder>
                                    <Label text="No users found"/>
                                </placeholder>
                                <columns>
                                    <TableColumn fx:id="usernameColumn" text="Username" prefWidth="200"/>
                                    <TableColumn fx:id="roleColumn" text="Role" prefWidth="120"/>
                                    <TableColumn fx:id="createdAtColumn" text="Created Date" prefWidth="180"/>
                                </columns>
                            </TableView>
                        </center>
                    </BorderPane>
                </content>
            </Tab>

            <!-- Events Tab -->
            <Tab text="Events">
                <content>
                    <BorderPane>
                        <top>
                            <ToolBar fx:id="eventsToolbar">
                                <Button fx:id="createEventButton" text="+ Create Event"
                                        onAction="#handleCreateEvent"/>
                                <Button fx:id="editEventButton" text="Edit Event"
                                        onAction="#handleEditEvent" disable="true"/>
                                <Button fx:id="deleteEventButton" text="Delete Event"
                                        onAction="#handleDeleteEvent" disable="true"/>
                                <Button fx:id="toggleActivateButton" text="Activate"
                                        onAction="#handleToggleActivate" disable="true"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="eventsStatusLabel"
                                       style="-fx-text-fill: #666;"/>
                            </ToolBar>
                        </top>
                        <center>
                            <TableView fx:id="eventsTable">
                                <placeholder>
                                    <Label text="No events found"/>
                                </placeholder>
                                <columns>
                                    <TableColumn fx:id="eventNameColumn" text="Name" prefWidth="180"/>
                                    <TableColumn fx:id="eventDateColumn" text="Date" prefWidth="135"/>
                                    <TableColumn fx:id="eventVenueColumn" text="Venue" prefWidth="150"/>
                                    <TableColumn fx:id="eventDescColumn" text="Description" prefWidth="160"/>
                                    <TableColumn fx:id="eventStatusColumn" text="Status" prefWidth="90"/>
                                </columns>
                            </TableView>
                        </center>
                    </BorderPane>
                </content>
            </Tab>

            <!-- Seating Tab -->
            <Tab text="Seating">
                <content>
                    <BorderPane>
                        <top>
                            <ToolBar fx:id="zonesToolbar">
                                <ComboBox fx:id="zonesEventSelector" promptText="Select event…" prefWidth="220"/>
                                <Button fx:id="zonesAddButton" text="+ Add Zone"
                                        onAction="#handleAddZone" disable="true"/>
                                <Button fx:id="zonesEditButton" text="Edit Zone"
                                        onAction="#handleEditZone" disable="true"/>
                                <Button fx:id="zonesDeleteButton" text="Delete Zone"
                                        onAction="#handleDeleteZone" disable="true"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="zonesStatusLabel"
                                       style="-fx-text-fill: #666;"/>
                            </ToolBar>
                        </top>
                        <center>
                            <TableView fx:id="zonesTable">
                                <placeholder>
                                    <Label text="Select an event in the Events tab to manage zones"/>
                                </placeholder>
                                <columns>
                                    <TableColumn fx:id="zonesNameColumn" text="Zone Name" prefWidth="200"/>
                                    <TableColumn fx:id="zonesPriceColumn" text="Price (€)" prefWidth="120"/>
                                    <TableColumn fx:id="zonesSeatCountColumn" text="Seat Count" prefWidth="100"/>
                                </columns>
                            </TableView>
                        </center>
                    </BorderPane>
                </content>
            </Tab>

        </TabPane>
    </center>

</BorderPane>
