<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.ticketsync.controller.LayoutViewTabController">
    <top>
        <VBox spacing="0">
            <ToolBar>
                <Label text="Event:"/>
                <ComboBox fx:id="layoutEventSelector" prefWidth="220" promptText="Select event…"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="layoutExportButton" text="Export Layout"
                        disable="true" onAction="#handleExportLayout"/>
            </ToolBar>
            <!-- Stats context panel -->
            <HBox spacing="24" styleClass="layout-summary-bar">
                <Label fx:id="layoutEventNameLabel" text="No event selected"
                       styleClass="layout-summary-title"/>
                <Separator orientation="VERTICAL"/>
                <Label fx:id="layoutTotalLabel" text="Total: —"/>
                <Label fx:id="layoutAvailableLabel" text="Available: —" styleClass="layout-summary-available"/>
                <Label fx:id="layoutSoldLabel" text="Sold: —" styleClass="layout-summary-sold"/>
                <Label fx:id="layoutDisabledLabel" text="Disabled: —" styleClass="layout-summary-disabled"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <ScrollPane fx:id="layoutScrollPane" fitToHeight="false" fitToWidth="false"
                    hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED">
            <Canvas fx:id="layoutCanvas" width="800" height="600"/>
        </ScrollPane>
    </center>
    <bottom>
        <Label fx:id="layoutHoverLabel" styleClass="canvas-hover-label"/>
    </bottom>
</BorderPane>
