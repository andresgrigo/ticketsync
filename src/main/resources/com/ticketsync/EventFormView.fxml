<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>

<GridPane hgap="10" vgap="12" prefWidth="420"
          xmlns="http://javafx.com/javafx/21"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.ticketsync.controller.EventFormController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <columnConstraints>
        <ColumnConstraints minWidth="130" halignment="RIGHT"/>
        <ColumnConstraints hgrow="ALWAYS"/>
    </columnConstraints>

    <!-- Row 0: Name -->
    <Label text="Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <TextField fx:id="nameField" promptText="Enter event name"
               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

    <!-- Row 1: Date -->
    <Label text="Date:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    <DatePicker fx:id="eventDatePicker"
                GridPane.rowIndex="1" GridPane.columnIndex="1"/>

    <!-- Row 2: Time -->
    <Label text="Time (HH:mm):" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <TextField fx:id="timeField" promptText="HH:mm"
               GridPane.rowIndex="2" GridPane.columnIndex="1"/>

    <!-- Row 3: Venue -->
    <Label text="Venue:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
    <TextField fx:id="venueField" promptText="Enter venue"
               GridPane.rowIndex="3" GridPane.columnIndex="1"/>

    <!-- Row 4: Description -->
    <Label text="Description:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
    <TextArea fx:id="descriptionArea" prefRowCount="3" wrapText="true"
              promptText="Optional description"
              GridPane.rowIndex="4" GridPane.columnIndex="1"/>

    <!-- Row 5: Validation error — opacity-based toggle keeps row height constant -->
    <Label fx:id="errorLabel" text="" opacity="0"
           styleClass="form-error-label"
           GridPane.rowIndex="5" GridPane.columnIndex="0"
           GridPane.columnSpan="2"/>
</GridPane>
