<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ticketsync.controller.SelectionPanelController"
      fx:id="rootContainer"
      spacing="12"
      prefWidth="320"
      style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8;">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <Label fx:id="headerLabel"
           text="Selected Seats (0 seats)"
           style="-fx-font-size: 16; -fx-font-weight: bold;"/>

    <StackPane VBox.vgrow="ALWAYS">
        <VBox spacing="12" fillWidth="true">
            <Label fx:id="emptyStateLabel"
                   text="No seats selected - click seats on map to begin"
                   wrapText="true"
                   style="-fx-text-fill: #616161;"/>

            <VBox fx:id="selectionContent" spacing="12" visible="false" managed="false">
                <ListView fx:id="selectedSeatsListView"
                          prefHeight="180"
                          VBox.vgrow="ALWAYS"/>

                <Label fx:id="countdownLabel"
                       text="Lock expires in: 60"
                       style="-fx-text-fill: #616161;"/>

                <Label fx:id="totalPriceLabel"
                       text="Total: EUR0.00"
                       style="-fx-font-size: 18; -fx-font-weight: bold;"/>

                <HBox spacing="10">
                    <Button fx:id="confirmPurchaseButton"
                            text="Confirm Purchase"
                            defaultButton="true"
                            disable="true"
                            onAction="#handleConfirmPurchase"
                            maxWidth="1.7976931348623157E308"
                            HBox.hgrow="ALWAYS"/>
                    <Button fx:id="releaseLockButton"
                            text="Release Lock"
                            disable="true"
                            onAction="#handleReleaseLock"/>
                </HBox>
            </VBox>
        </VBox>

        <StackPane fx:id="processingOverlay"
                   visible="false"
                   managed="false"
                   style="-fx-background-color: rgba(255,255,255,0.75);">
            <ProgressIndicator prefWidth="48" prefHeight="48"/>
        </StackPane>
    </StackPane>
</VBox>
